{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "plugins": [
    "./biome-plugins/microcopy-ellipsis.grit",
    "./biome-plugins/no-loosely-typed-webcontents-ipc.grit",
    "./biome-plugins/no-resolved-value-theme-source.grit",
    "./biome-plugins/no-unportaled-editor-content.grit"
  ],
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noReactForwardRef": "error"
      },
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "react": {
                "importNames": ["useCallback", "useMemo", "memo"],
                "message": "The highlighted React API is flagged.\nWe use the React Compiler, which automatically memoizes where needed.\nIn 99% of cases, manual memoization is unnecessary."
              }
            },
            "patterns": [
              {
                "group": "react",
                "importNamePattern": "useContext",
                "message": "Use the `use()` hook instead."
              }
            ]
          }
        }
      }
    }
  },
  "overrides": [
    {
      // Observer A origin discipline. Scoped to the one file that owns the
      // observer-cross-CRDT transact spine. Inside this file every
      // `doc.transact(fn, origin)` must pass `OBSERVER_SYNC_ORIGIN` as the
      // second argument; bare `doc.transact(fn)` (or a wrong origin) routes the
      // write to `openknowledge-service` and breaks per-session UndoManager
      // attribution. Other server files routing through
      // `session.dc.document.transact(fn, session.origin)` are out of scope -
      // that contract is enforced by `paired-write-enforcement.test.ts`.
      "includes": [
        "packages/server/src/server-observers.ts",
        "biome-plugins/__fixtures__/path-conditional-map-driven-origin.fixture.tsx"
      ],
      "plugins": ["./biome-plugins/path-conditional-map-driven-origin.grit"]
    },
    {
      // Codemod handler TODO-stub grep. The substrate-adapter codemod seeds
      // per-substrate handler scaffolds under
      // packages/md-conformance/src/substrates/<id>/handlers/{mdast-to-pm,
      // pm-to-mdast-node,pm-to-mdast-mark}/<key>.ts, each containing
      // `throw new Error("TODO: implement <substrate>:<dir>/<key>")`. This rule
      // greps for stubs that survive to lint time so an unfinished handler
      // can't pass review. It is NOT an exhaustiveness check: the per-substrate
      // node-set traversal belongs to a suite-self-consistency gate, and the
      // handlers-table type check against ICstEngine is the compile-time
      // backstop for missing methods. Scoped narrowly to the handlers/ subtree
      // under any substrate dir, so the codemod implementation + harness tests +
      // oracles (which legitimately produce strings containing "TODO: implement"
      // in their own contexts) are out of scope.
      "includes": [
        "packages/md-conformance/src/substrates/*/handlers/**/*.ts",
        "biome-plugins/__fixtures__/cst-pm-handler-todo-stub.fixture.tsx"
      ],
      "plugins": ["./biome-plugins/cst-pm-handler-todo-stub.grit"]
    },
    {
      // Class-proof DSL registration discipline. Per the dsl.ts contract
      // (`defineClassProof` from packages/md-conformance/src/class-proofs/dsl.ts),
      // class-proof registrations MUST live in the canonical proofs/ dir so
      // run-all.ts's manifest stays the single source of truth, and EVERY
      // registration MUST pass `predicate` + `proof` options. The plugin's
      // override scope EXCLUDES the canonical proofs/ dir — inside the dir,
      // TypeScript's `ClassProofOptions<M>` signature is the missing-args
      // backstop. Outside the dir, any `defineClassProof(...)` call fires
      // (= wrong location), and missing-args fires an additional diagnostic.
      "includes": [
        "**/*.ts",
        "**/*.tsx",
        "!**/node_modules/**",
        "!**/dist/**",
        "!**/*.test.ts",
        "!**/*.test.tsx",
        "!packages/md-conformance/src/class-proofs/proofs/**",
        "biome-plugins/__fixtures__/class-proof-registration-discipline.fixture.tsx"
      ],
      "plugins": ["./biome-plugins/class-proof-registration-discipline.grit"]
    },
    {
      // Apple-Event / IPC roundtrip toPass budget enforcement is scoped to
      // the desktop-smoke files (and the plugin's own fixture for testing).
      // packages/app's *.e2e.ts files drive Chromium in-process, NOT macOS
      // `open(1)` Apple-Event dispatch, so their sub-15s toPass budgets are
      // legitimate (fast in-process roundtrip, no Launch Services latency).
      // Pairs with `tests/smoke/calibration.test.ts` Invariant B, which is
      // scoped to the same surface via `TOPASS_BUDGET_FILES`.
      "includes": [
        "packages/desktop/tests/smoke/deep-link.e2e.ts",
        "packages/desktop/tests/smoke/external-link.e2e.ts",
        "biome-plugins/__fixtures__/playwright-topass-budget.fixture.tsx"
      ],
      "plugins": ["./biome-plugins/playwright-topass-budget.grit"]
    },
    {
      // One-shot `expect(await locator.count())` reads never retry and are
      // the canonical hidden-flake assertion shape (2026-06 e2e audit).
      // Scoped to the browser e2e suites (all three dirs the e2e-stop-rules
      // source-scan also covers) + the plugin's own fixture. Not workspace-
      // wide: outside Playwright specs, `.count()` is usually not a Locator
      // and the web-first rewrite does not apply.
      "includes": [
        "packages/app/tests/stress/**/*.e2e.ts",
        "packages/app/tests/visual/**/*.e2e.ts",
        "packages/app/tests/a11y/**/*.e2e.ts",
        "biome-plugins/__fixtures__/playwright-prefer-to-have-count.fixture.tsx"
      ],
      "plugins": ["./biome-plugins/playwright-prefer-to-have-count.grit"]
    },
    {
      // UI primitives discipline (see PR #937 retrospective). Scoped to
      // packages/{app,desktop,plugin}/src/**/*.tsx — production UI surfaces.
      // Exemptions:
      //  - packages/app/src/editor/** — ProseMirror NodeViews + chrome legitimately
      //    render raw HTML for measurement / PM-managed DOM (matches the existing
      //    a11y/useSemanticElements suppressions in editor/*).
      //  - packages/app/src/components/ui/** — these ARE the shadcn primitive
      //    wrappers; they must render raw HTML by definition.
      //  - *.test.tsx / *.dom.test.tsx — test fixtures aren't user-facing UI.
      // Pre-rule backlog (files outside the exemptions that pre-date the rule)
      // is annotated via `// biome-ignore-all lint/plugin/no-raw-html-interactive-element:`
      // at the top of each offender file — the comment list is the visible
      // migration backlog. New files cannot opt out: PR review treats the
      // suppression header as a backlog marker, not a free pass.
      "includes": [
        "packages/app/src/**/*.tsx",
        "packages/desktop/src/**/*.tsx",
        "packages/plugin/src/**/*.tsx",
        "!packages/app/src/editor/**",
        "!packages/app/src/components/ui/**",
        "!**/*.test.tsx",
        "!**/*.dom.test.tsx",
        "biome-plugins/__fixtures__/no-raw-html-interactive-element.fixture.tsx"
      ],
      "plugins": ["./biome-plugins/no-raw-html-interactive-element.grit"]
    },
    {
      // Internal developer tooling for the static-string audit. Uses ts-morph's
      // untyped node accessors, embeds `${...}` placeholder literals, and a few
      // safe non-null assertions — none of which affect production code.
      "includes": ["packages/app/scripts/audit-strings/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noTemplateCurlyInString": "off",
            "noAssignInExpressions": "off",
            "noShadowRestrictedNames": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "complexity": {
            "noUselessSwitchCase": "off"
          },
          "correctness": {
            "noUnusedFunctionParameters": "off"
          }
        }
      }
    },
    {
      // lume-qa is a macOS-VM E2E test harness (Electron CDP + AX driver).
      // It deliberately uses post-guard non-null assertions — e.g.
      // `scenario.verification!.rungs!` after a `hasRungs` predicate, and
      // `app.axBundleId!` after `getAxApp()` has already validated the field —
      // because the guards live one call-frame up and the compiler can't see
      // through them. It also assembles shell-command strings via `+`
      // concatenation in a few spots where a template literal reads no better.
      // These are test-harness style allowances, not production code; the
      // assertions encode invariants the surrounding guards enforce, so
      // stripping the `!` (or rewriting to `?.`) would change semantics.
      // Correctness rules (e.g. noUnusedVariables) stay ON for this tree.
      "includes": ["packages/desktop/tests/lume-qa/**"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off",
            "useTemplate": "off"
          }
        }
      }
    },
    {
      // Byte-fidelity round-trip oracle ban, scoped to the public-mirrored test
      // surface. `serialize(parse(x))` (or the MarkdownManager method form)
      // asserted equal to the same `x` is the engine's byte-identity correctness
      // oracle — private quality-bar IP. It legitimately lives in the engine
      // fidelity suite (packages/app/tests/fidelity), the markdown + bridge
      // precision suites, and the enumerated byte-oracle tests; those are
      // excluded from the public mirror, and are excluded here too so the oracle
      // stays allowed there but forbidden on the public surface.
      // packages/md-conformance is the private conformance estate
      // (also mirror-excluded). The fixture is in scope so its planted oracle
      // drives the fixture-file test; the Bridge-invariant comparator
      // `normalizeBridge(a) === normalizeBridge(b)` (precedent #38) is the public
      // contract and is left untouched by the rule, not by this scope.
      "includes": [
        "packages/**/*.test.ts",
        "packages/**/*.test.tsx",
        "packages/**/*.e2e.ts",
        "!packages/md-conformance/**",
        "!packages/app/tests/fidelity/**",
        "!packages/core/src/markdown/**/*.test.ts",
        "!packages/core/src/bridge/**/*.test.ts",
        "!packages/server/src/prd-6654-multi-client-repro.test.ts",
        "!packages/app/tests/integration/source-mode-byte-preservation.test.ts",
        "!packages/app/tests/integration/init-load-byte-stable.test.ts",
        "!packages/app/tests/integration/init-load-byte-stable-corpus-coverage.test.ts",
        "!packages/app/tests/stress/init-load-byte-stable.e2e.ts",
        "!packages/app/tests/stress/single-file-ephemeral.e2e.ts",
        "biome-plugins/__fixtures__/no-roundtrip-identity-oracle.fixture.tsx"
      ],
      "plugins": ["./biome-plugins/no-roundtrip-identity-oracle.grit"]
    }
  ],
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      // napi-rs build artifacts: a per-platform `.node` binary and the
      // auto-generated CommonJS loader + d.ts. Regenerated by `napi build`,
      // gitignored, and owned by the napi-rs toolchain's formatting.
      "!packages/native-config/index.js",
      "!packages/native-config/index.d.ts",
      "!packages/native-config/target",
      "!**/.next",
      "!**/.source",
      "!**/.turbo",
      "!**/tmp",
      "!**/test-results",
      "!**/playwright-report",
      "!**/next-env.d.ts",
      "!.claude",
      // .agents/skills, .codex/skills under public/open-knowledge/
      // are real dirs of per-skill symlinks back to the repo-root canonical
      // at ../../../.agents/skills/<skill>. Without these excludes biome
      // traverses through the symlinks and lints files outside this subtree's
      // scope (including team-skills sources whose syntax is owned by
      // upstream). Skill formatting is owned by cross-harness-skills-sync.
      "!.agents/skills",
      "!.codex/skills",
      "!.bun",
      "!specs",
      "!reports",
      "!evidence",
      "!meta",
      "!docs/bun.lock",
      "!worktrees",
      "!**/rehype-plugins/fixtures",
      "!**/tests/perf/results",
      "!**/tests/perf/playwright-results",
      "!packages/desktop/out",
      "!packages/desktop/dist-desktop",
      // The md-audit framework was folded under packages/md-conformance/md-audit/
      // but is a self-contained unit with its own tsconfig + conventions; it was
      // never OK-biome-formatted (it lived outside the lint scan targets before
      // the fold) and ships a generated docs/byte-preservation-audit.json. Its
      // own typecheck + tests run via `bun --cwd packages/md-conformance/md-audit`
      // and the md-conformance test task; keep it out of OK's biome format scan.
      "!packages/md-conformance/md-audit",
      // Mechanically generated by scripts/enumerate-conformance.ts (JSON.stringify);
      // its byte format is owned by the generator, not biome (biome would collapse
      // the short per-entry testTier arrays the generator emits expanded). Content
      // correctness is enforced by check-conformance-fresh.ts (sha256 pin), so the
      // format scan adds nothing. Path is copybara-excluded, like the md-audit line.
      "!packages/md-conformance/conformance-catalog.json",
      // Mechanically extracted by src/corpora/authoring/extract-gfm-extensions.ts
      // (JSON.stringify); its byte format is owned by the extractor, not biome
      // (biome would collapse the single-element `extensions` arrays the extractor
      // emits expanded). Content correctness is enforced by the re-extraction
      // freshness gate (gfm-extensions-freshness.test.ts). Path is copybara-excluded.
      "!packages/md-conformance/corpora/gfm-extensions.json"
    ]
  }
}
